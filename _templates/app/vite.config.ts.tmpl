import { defineConfig } from 'vite';
import react from '@vitejs/plugin-react';

// Web frontend on 5173, Fastify backend on 5174.
// /api requests are proxied to the backend so the frontend can use same-origin fetch.
export default defineConfig({
  plugins: [react()],
  server: {
    port: 5173,
    proxy: {
      '/api': {
        target: 'http://localhost:5174',
        changeOrigin: true,
      },
    },
  },
});
