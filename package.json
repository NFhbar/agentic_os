{
  "name": "agentic-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-extending agentic OS — root tooling (markdown formatting + structural test suite). App-level tooling lives in each app's own package.json.",
  "scripts": {
    "md:check": "prettier --check \"**/*.md\"",
    "md:format": "prettier --write \"**/*.md\"",
    "pretest": "node .claude/hooks/rebuild-vault-index.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.3.3",
    "vitest": "^2.1.0"
  }
}
