# agentic-os dashboard server — environment variables
#
# Copy this to `.env` (same directory) and fill in real values. The .env file
# is gitignored. The server loads it at boot via `server/load-env.ts`.
# Shell-exported values (e.g. `export SLACK_BOT_TOKEN=...`) take priority over
# anything set here — that lets per-invocation overrides work without editing.
#
# See standard-env-config.md for the loading convention.

# ── Dashboard server ─────────────────────────────────────────────────────────
# Port the Fastify API server listens on. Default 5174 (the Vite dev server
# proxies /api/* to this port). Override only if 5174 collides with another
# process on this machine.
# PORT=5174

# ── Slack notifications ──────────────────────────────────────────────────────
# Bot-token mode (preferred): set SLACK_BOT_TOKEN to a Bot User OAuth Token
# (starts with xoxb-). The Slack adapter detects this and routes per-rule via
# chat.postMessage to whatever channel each rule's delivery.slack_channel
# specifies. Required scopes: chat:write (and chat:write.public to post in
# channels the bot hasn't been invited to).
# SLACK_BOT_TOKEN=xoxb-...

# Webhook mode (fallback): set SLACK_WEBHOOK_URL to an Incoming Webhook URL.
# The webhook is bound to ONE channel chosen at app-install time; per-rule
# delivery.slack_channel is ignored in this mode.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal Access Token used by server-side routes that hit the GitHub API
# directly (PR fetch, CI snapshot, etc). The mcps/github MCP server has its
# own mcps/github/.env for skill-side GitHub calls; this is the dashboard
# server's copy.
# GITHUB_TOKEN=ghp_...
